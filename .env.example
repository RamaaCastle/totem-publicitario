# ============================================================
# SIGNAGE PLATFORM - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# --- APPLICATION ---
NODE_ENV=development
APP_NAME="Signage Platform"
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
PLAYER_URL=http://localhost:3002

# --- BACKEND ---
BACKEND_PORT=3001
BACKEND_HOST=0.0.0.0

# --- ADMIN PANEL ---
ADMIN_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# --- DATABASE (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=signage_db
DB_USER=signage_user
DB_PASSWORD=change_this_strong_password
DATABASE_URL=postgresql://signage_user:change_this_strong_password@localhost:5432/signage_db

# --- REDIS ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password
REDIS_URL=redis://:change_this_redis_password@localhost:6379

# --- JWT AUTH ---
# Generate with: openssl rand -base64 64
JWT_SECRET=change_this_to_a_very_long_random_secret_min_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_to_another_very_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# --- FILE STORAGE ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=500
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif
ALLOWED_VIDEO_TYPES=video/mp4,video/webm

# --- STORAGE PROVIDER: local | s3 ---
STORAGE_PROVIDER=local

# --- AWS S3 (optional, for production) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# --- CLOUDINARY (for specific organizations) ---
CLOUDINARY_CLOUD_NAME=dnyuwzead
CLOUDINARY_API_KEY=559791155429265
CLOUDINARY_API_SECRET=jaAX4ZUu2VyMpGQPYuFeyY4TDqg
CLOUDINARY_UPLOAD_PRESET=Pedraza
# Comma-separated org slugs that upload to Cloudinary instead of local storage
CLOUDINARY_ORG_SLUGS=pedraza

# --- RATE LIMITING ---
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# --- ADMIN SEED (first run) ---
ADMIN_EMAIL=admin@signage.local
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME="System Administrator"

# --- PLAYER AUTO-UPDATE ---
# Increment PLAYER_VERSION_CODE to trigger update on all devices
PLAYER_VERSION_CODE=1
PLAYER_VERSION_NAME=1.0.0
# Full URL to the APK file (served from /downloads/ or any CDN)
PLAYER_APK_URL=http://187.77.53.136/downloads/player-latest.apk
# Path where APK files are stored on disk (EasyPanel volume)
DOWNLOADS_PATH=/app/downloads

# --- LOGS ---
LOG_LEVEL=debug
