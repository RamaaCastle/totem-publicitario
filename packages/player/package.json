{
  "name": "player",
  "version": "1.0.0",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/start-dev.js",
    "dev:totem": "node scripts/start-dev-totem.js",
    "build": "unset ELECTRON_RUN_AS_NODE && NODE_PATH=./node_modules electron-vite build && electron-builder",
    "preview": "unset ELECTRON_RUN_AS_NODE && NODE_PATH=./node_modules electron-vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "build:web": "vite build",
    "build:android": "pnpm build:web && npx cap sync android && npx cap build android"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "axios": "^1.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.7.5",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^30.1.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.signage.player",
    "productName": "Signage Player",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    }
  }
}
